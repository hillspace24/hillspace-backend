{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "HillSpace API",
    "description": "Estate management backend — Auth, Listings, Search, Verification, Escrow.\n\n1. Set `baseUrl` (default http://localhost:3000/api)\n2. Run **Auth → Register** or **Login** — tokens are saved automatically\n3. Authenticated requests use `{{accessToken}}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "listingId", "value": "" },
    { "key": "escrowId", "value": "" },
    { "key": "verificationId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (data.accessToken) pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ada\",\n  \"lastName\": \"Lovelace\",\n  \"email\": \"ada@hillspace.test\",\n  \"phone\": \"+2348012345678\",\n  \"password\": \"password123\",\n  \"role\": \"buyer\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Register a user. Role can be buyer | seller | agent (not admin)."
          }
        },
        {
          "name": "Register Seller",
          "event": [
            {
              "listen": "test",
              "script": {
